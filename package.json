{
  "name": "array-scope",
  "displayName": "ArrayScope Scientific Image Viewer",
  "description": "Read-only, progressive scientific image viewer for NPY and TIFF files.",
  "version": "0.1.0",
  "publisher": "arrayscope",
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Visualization",
    "Other"
  ],
  "keywords": [
    "scientific",
    "image",
    "numpy",
    "npy",
    "tiff"
  ],
  "extensionKind": [
    "workspace"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onCustomEditor:scientificImageViewer.viewer"
  ],
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "clean": "rm -rf dist coverage *.vsix",
    "build": "node esbuild.mjs",
    "build:integration": "tsc -p tsconfig.integration.json",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:integration": "npm run build && npm run build:integration && node dist/test/runTest.js",
    "test:watch": "vitest",
    "package": "npm run clean && npm run typecheck && npm test && npm run build && vsce package --no-dependencies --allow-missing-repository"
  },
  "contributes": {
    "customEditors": [
      {
        "viewType": "scientificImageViewer.viewer",
        "displayName": "Scientific Image Viewer",
        "selector": [
          { "filenamePattern": "*.npy" },
          { "filenamePattern": "*.tif" },
          { "filenamePattern": "*.tiff" }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      { "command": "scientificImageViewer.tool.rectangle", "title": "Scientific Image Viewer: Rectangle Selection" },
      { "command": "scientificImageViewer.tool.ellipse", "title": "Scientific Image Viewer: Ellipse Selection" },
      { "command": "scientificImageViewer.tool.line", "title": "Scientific Image Viewer: Line Selection" },
      { "command": "scientificImageViewer.tool.polygon", "title": "Scientific Image Viewer: Polygon Selection" },
      { "command": "scientificImageViewer.tool.sampler", "title": "Scientific Image Viewer: Sampler" },
      { "command": "scientificImageViewer.computeStatistics", "title": "Scientific Image Viewer: Calculate Statistics" },
      { "command": "scientificImageViewer.tool.magnifier", "title": "Scientific Image Viewer: Magnifier" },
      { "command": "scientificImageViewer.tool.pan", "title": "Scientific Image Viewer: Pan" },
      { "command": "scientificImageViewer.autoContrast", "title": "Scientific Image Viewer: Auto Contrast" },
      { "command": "scientificImageViewer.clearSelection", "title": "Scientific Image Viewer: Clear Selection" },
      { "command": "scientificImageViewer.fitToWindow", "title": "Scientific Image Viewer: Fit to Window" },
      { "command": "scientificImageViewer.actualPixels", "title": "Scientific Image Viewer: Actual Pixels" },
      { "command": "scientificImageViewer.zoomIn", "title": "Scientific Image Viewer: Zoom In" },
      { "command": "scientificImageViewer.zoomOut", "title": "Scientific Image Viewer: Zoom Out" },
      { "command": "scientificImageViewer.nextSlice", "title": "Scientific Image Viewer: Next Slice" },
      { "command": "scientificImageViewer.previousSlice", "title": "Scientific Image Viewer: Previous Slice" }
    ],
    "keybindings": [
      { "command": "scientificImageViewer.tool.rectangle", "key": "r", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.tool.ellipse", "key": "e", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.tool.line", "key": "l", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.tool.polygon", "key": "p", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.tool.sampler", "key": "i", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.computeStatistics", "key": "ctrl+alt+shift+s", "mac": "cmd+alt+shift+s", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.tool.magnifier", "key": "z", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.tool.pan", "key": "h", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.clearSelection", "key": "ctrl+alt+backspace", "mac": "cmd+alt+backspace", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.fitToWindow", "key": "f", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.actualPixels", "key": "1", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.nextSlice", "key": "]", "when": "activeCustomEditorId == scientificImageViewer.viewer" },
      { "command": "scientificImageViewer.previousSlice", "key": "[", "when": "activeCustomEditorId == scientificImageViewer.viewer" }
    ],
    "configuration": {
      "title": "Scientific Image Viewer",
      "properties": {
        "scientificImageViewer.localCacheMB": {
          "type": "number",
          "default": 256,
          "minimum": 32,
          "description": "Maximum numeric tile cache size in each local webview, in MiB."
        },
        "scientificImageViewer.remoteCacheMB": {
          "type": "number",
          "default": 512,
          "minimum": 32,
          "description": "Maximum decoded tile cache size on the extension host, in MiB."
        },
        "scientificImageViewer.tileSize": {
          "type": "number",
          "default": 256,
          "enum": [128, 256, 512],
          "description": "Tile edge length in pixels."
        }
      }
    }
  },
  "dependencies": {
    "geotiff": "^3.0.5",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/vscode": "^1.100.0",
    "@vscode/test-electron": "^3.0.0",
    "@vscode/vsce": "^3.9.2",
    "esbuild": "^0.28.1",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  }
}
